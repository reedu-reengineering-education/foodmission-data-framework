// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Food {
  id              String @id @default(uuid())
  name            String
  description     String?
  barcode         String? @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String

  // --- Product metadata ---
  brands          String?
  categories      String[] // OpenFoodFacts category tags e.g. ["en:spreads","en:sweet-spreads"]
  labels          String[] // e.g. ["en:vegetarian","en:no-gluten"]
  quantity        String? // e.g. "400 g"
  servingSize     String? // e.g. "15 g"
  ingredientsText String?
  allergens       String[] // e.g. ["en:milk","en:nuts","en:soybeans"]
  traces          String[] // possible cross-contamination allergens
  countries       String[] // where sold, e.g. ["en:france","en:germany"]
  origins         String? // where ingredients come from, e.g. "European Union"
  manufacturingPlaces String? // where product is manufactured
  imageUrl        String?
  imageFrontUrl   String?

  // --- Nutriments (per 100 g) ---
  nutritionDataPer String? // "100g" or "serving" — basis of nutrition values
  energyKcal100g     Float?
  energyKj100g       Float?
  fat100g            Float?
  saturatedFat100g   Float?
  transFat100g       Float?
  cholesterol100g    Float?
  carbohydrates100g  Float?
  sugars100g         Float?
  addedSugars100g    Float?
  fiber100g          Float?
  proteins100g       Float?
  salt100g           Float?
  sodium100g         Float?
  vitaminA100g       Float?
  vitaminC100g       Float?
  calcium100g        Float?
  iron100g           Float?
  potassium100g      Float?
  magnesium100g      Float?
  zinc100g           Float?

  // --- Full nutriments JSON (everything from OpenFoodFacts as-is) ---
  nutrimentsRaw Json? // Complete nutriments object for fields not covered above

  // --- Scores & grades ---
  nutriscoreGrade String? // A, B, C, D, E
  nutriscoreScore Int?
  novaGroup       Int? // 1 = unprocessed, 4 = ultra-processed
  ecoscoreGrade   String? // a, b, c, d, e, unknown
  carbonFootprint Float? // CO₂ from known ingredients (kg CO₂e / kg product)

  // --- Nutrient levels (traffic lights) ---
  nutrientLevels Json? // { fat: "high", sugars: "high", salt: "low", "saturated-fat": "high" }

  // --- Diet / ingredient analysis ---
  isVegan      Boolean?
  isVegetarian Boolean?
  isPalmOilFree Boolean?
  ingredientsAnalysisTags String[] // raw tags e.g. ["en:palm-oil","en:non-vegan","en:vegetarian"]

  // --- Packaging ---
  packagingTags     String[] // e.g. ["en:plastic","fr:pot-en-verre"]
  packagingMaterials String[] // e.g. ["en:clear-glass","en:pp-5-polypropylene"]
  packagingRecycling String[] // e.g. ["en:recycle-in-glass-bin"]
  packagingText     String?

  // --- Data quality ---
  completeness Float? // 0.0 - 1.0

  // --- Relations ---
  shoppingListItem ShoppingListItem[]
  pantryItem       PantryItem[]

  @@index([name])
  @@index([createdAt])
  @@index([nutriscoreGrade])
  @@index([novaGroup])
  @@map("foods")
}

model User {
  id                             String         @id @default(uuid())
  keycloakId                     String         @unique
  email                          String         @unique
  firstName                      String
  lastName                       String
  preferences                    Json           @default("{}") // Flexible JSON for app-specific preferences
  settings                       Json           @default("{}") // Flexible JSON for app-specific settings
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime       @updatedAt
  shouldAutoAddToPantry Boolean        @default(true)
  shoppingList                   ShoppingList[]
  pantry                         Pantry[]
  recipes                        Recipe[]
  meals                          Meal[]
  mealLogs                       MealLog[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model ShoppingList {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id])
  items ShoppingListItem[]

  @@unique([userId, title])
  @@index([userId])
}

model ShoppingListItem {
  id             String  @id @default(uuid())
  quantity       Int     @default(1)
  unit           Unit    @default(PIECES)
  notes          String?
  checked        Boolean @default(false)
  shoppingListId String
  foodId         String

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  food         Food         @relation(fields: [foodId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shoppingListId, foodId])
  @@index([shoppingListId])
  @@map("shopping_list_items")
}

model Pantry {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id])
  items PantryItem[]

  @@unique([userId, title])
  @@index([userId])
}

model PantryItem {
  id         String    @id @default(uuid())
  quantity   Int       @default(1)
  unit       Unit      @default(PIECES)
  notes      String?
  expiryDate DateTime?
  pantryId   String
  foodId     String

  pantry Pantry @relation(fields: [pantryId], references: [id], onDelete: Cascade)
  food   Food   @relation(fields: [foodId], references: [id])
  meals  Meal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pantryId])
  @@map("pantry_items")
}

enum Unit {
  PIECES
  G
  KG
  ML
  L
  CUPS
}

enum TypeOfMeal {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  SPECIAL_DRINKS
}

enum MealType {
  SALAD
  MEAT
  PASTA
  RICE
  VEGAN
}

model Meal {
  id                  String     @id @default(uuid())
  name                String
  mealType            MealType
  calories            Int?
  proteins            Int?
  nutritionalInfo     Json?
  sustainabilityScore Float?
  price               Float?
  pantryItemId        String?
  barcode             String?    @unique
  userId              String
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  pantryItem PantryItem? @relation(fields: [pantryItemId], references: [id], onDelete: SetNull)
  user       User        @relation(fields: [userId], references: [id])
  recipes    Recipe[]
  mealLogs   MealLog[]
  @@index([userId])
  @@index([mealType])
}

model Recipe {
  id                  String   @id @default(uuid())
  userId              String
  mealId              String
  title               String
  description         String?
  instructions        String?
  prepTime            Int?
  cookTime            Int?
  servings            Int?
  difficulty          String?
  tags                String[]
  nutritionalInfo     Json?
  sustainabilityScore Float?
  price               Float?
  allergens           String[]
  rating              Float    @default(0)
  ratingCount         Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Restrict)
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([mealId])
  @@map("recipes")
}

model MealLog {
  id             String     @id @default(uuid())
  userId         String
  mealId         String
  typeOfMeal     TypeOfMeal
  timestamp      DateTime   @default(now())
  mealFromPantry Boolean    @default(false)
  eatenOut       Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Restrict)

  @@index([userId, timestamp])
  @@index([typeOfMeal])
  @@map("meal_logs")
}
