// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Food {
  id               String             @id @default(uuid())
  name             String
  description      String?
  barcode          String?            @unique
  openFoodFactsId  String?            @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  createdBy        String
  shoppingListItem ShoppingListItem[]
  pantryItem       PantryItem[]

  @@index([name])
  @@index([createdAt])
  @@map("foods")
}

model User {
  id                    String             @id @default(uuid())
  keycloakId            String             @unique
  email                 String             @unique
  firstName             String?
  lastName              String?
  username              String?            @unique
  yearOfBirth           Int?
  country               String?
  region                String?
  zip                   String?
  language              String?
  preferences           Json               @default("{}") // Flexible JSON for app-specific preferences
  settings              Json               @default("{}") // Flexible JSON for app-specific settings
  gender                Gender?
  annualIncome          AnnualIncomeLevel?
  educationLevel        EducationLevel?
  weightKg              Float?
  heightCm              Float?
  activityLevel         ActivityLevel?
  healthGoals           Json?              @default("{}")
  nutritionTargets      Json?              @default("{}")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  shouldAutoAddToPantry Boolean            @default(true)
  shoppingList          ShoppingList[]
  pantry                Pantry[]
  recipes                        Recipe[]
  meals                          Meal[]
  mealLogs                       MealLog[]
  challengeProgress     ChallengeProgress[]
  missionProgress       MissionProgress[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model ShoppingList {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id])
  items ShoppingListItem[]

  @@unique([userId, title])
  @@index([userId])
}

model ShoppingListItem {
  id             String  @id @default(uuid())
  quantity       Int     @default(1)
  unit           Unit    @default(PIECES)
  notes          String?
  checked        Boolean @default(false)
  shoppingListId String
  foodId         String

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  food         Food         @relation(fields: [foodId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shoppingListId, foodId])
  @@index([shoppingListId])
  @@map("shopping_list_items")
}

model Pantry {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id])
  items PantryItem[]

  @@unique([userId, title])
  @@index([userId])
}

model PantryItem {
  id         String    @id @default(uuid())
  quantity   Int       @default(1)
  unit       Unit      @default(PIECES)
  notes      String?
  expiryDate DateTime?
  pantryId   String
  foodId     String

  pantry Pantry @relation(fields: [pantryId], references: [id], onDelete: Cascade)
  food   Food   @relation(fields: [foodId], references: [id])
  meals  Meal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pantryId])
  @@map("pantry_items")
}

model Meal {
  id                  String   @id @default(uuid())
  name                String
  mealType            MealType
  calories            Int?
  proteins            Int?
  nutritionalInfo     Json?
  sustainabilityScore Float?
  price               Float?
  pantryItemId        String?
  barcode             String?  @unique
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  pantryItem PantryItem? @relation(fields: [pantryItemId], references: [id], onDelete: SetNull)
  user       User        @relation(fields: [userId], references: [id])
  recipes    Recipe[]
  mealLogs   MealLog[]

  @@index([userId])
  @@index([mealType])
}

model Recipe {
  id                  String   @id @default(uuid())
  userId              String
  mealId              String
  title               String
  description         String?
  instructions        String?
  prepTime            Int?
  cookTime            Int?
  servings            Int?
  difficulty          String?
  tags                String[]
  nutritionalInfo     Json?
  sustainabilityScore Float?
  price               Float?
  allergens           String[]
  rating              Float    @default(0)
  ratingCount         Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Restrict)
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([mealId])
  @@map("recipes")
}

model MealLog {
  id             String     @id @default(uuid())
  userId         String
  mealId         String
  typeOfMeal     TypeOfMeal
  timestamp      DateTime   @default(now())
  mealFromPantry Boolean    @default(false)
  eatenOut       Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Restrict)

  @@index([userId, timestamp])
  @@index([typeOfMeal])
  @@map("meal_logs")
}

model Mission {
  id                String            @id @default(uuid())
  title             String
  description       String
  available         Boolean           @default(false)
  startDate         DateTime
  endDate           DateTime
  missionProgresses MissionProgress[]
}

model MissionProgress {
  userId    String
  missionId String
  completed Boolean @default(false)
  progress  Float

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Restrict)

  @@id([userId, missionId])
}

model Challenge {
  id                  String              @id @default(uuid())
  title               String
  description         String
  available           Boolean             @default(false)
  startDate           DateTime
  endDate             DateTime
  challengeProgresses ChallengeProgress[]
}

model ChallengeProgress {
  userId      String
  challengeId String
  completed   Boolean @default(false)
  progress    Float

  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Restrict)

  @@id([userId, challengeId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
  PREFER_NOT_TO_SAY
}

// New enums for profile fields
enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum AnnualIncomeLevel {
  BELOW_10000
  FROM_10000_TO_19999
  FROM_20000_TO_34999
  FROM_35000_TO_49999
  FROM_50000_TO_74999
  FROM_75000_TO_99999
  ABOVE_100000
}

enum EducationLevel {
  NO_FORMAL_EDUCATION
  PRIMARY
  SECONDARY
  VOCATIONAL
  BACHELORS
  MASTERS
  DOCTORATE
}

enum Unit {
  PIECES
  G
  KG
  ML
  L
  CUPS
}

enum TypeOfMeal {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  SPECIAL_DRINKS
}

enum MealType {
  SALAD
  MEAT
  PASTA
  RICE
  VEGAN
}

