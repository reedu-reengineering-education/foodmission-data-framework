// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Food {
  id          String   @id @default(uuid())
  name        String
  description String?
  barcode     String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String

  // --- Product metadata ---
  brands              String?
  categories          String[] // OpenFoodFacts category tags e.g. ["en:spreads","en:sweet-spreads"]
  labels              String[] // e.g. ["en:vegetarian","en:no-gluten"]
  quantity            String? // e.g. "400 g"
  servingSize         String? // e.g. "15 g"
  ingredientsText     String?
  allergens           String[] // e.g. ["en:milk","en:nuts","en:soybeans"]
  traces              String[] // possible cross-contamination allergens
  countries           String[] // where sold, e.g. ["en:france","en:germany"]
  origins             String? // where ingredients come from, e.g. "European Union"
  manufacturingPlaces String? // where product is manufactured
  imageUrl            String?
  imageFrontUrl       String?

  // --- Nutriments (per 100 g) ---
  nutritionDataPer String? // "100g" or "serving" — basis of nutrition values
  energyKcal       Float?
  energyKj         Float?
  fat              Float?
  saturatedFat     Float?
  transFat         Float?
  cholesterol      Float?
  carbohydrates    Float?
  sugars           Float?
  addedSugars      Float?
  fiber            Float?
  proteins         Float?
  salt             Float?
  sodium           Float?
  vitaminA         Float?
  vitaminC         Float?
  vitaminD         Float? // Vitamin D (µg) — used in recipe nutrition aggregation
  calcium          Float?
  iron             Float?
  potassium        Float?
  magnesium        Float?
  zinc             Float?

  // --- Full nutriments JSON (everything from OpenFoodFacts as-is) ---
  nutrimentsRaw Json? // Complete nutriments object for fields not covered above

  // --- Scores & grades ---
  nutriscoreGrade String? // A, B, C, D, E
  nutriscoreScore Int?
  novaGroup       Int? // 1 = unprocessed, 4 = ultra-processed
  ecoscoreGrade   String? // a, b, c, d, e, unknown
  carbonFootprint Float? // CO₂ from known ingredients (kg CO₂e / kg product)

  // --- Nutrient levels (traffic lights) ---
  nutrientLevels Json? // { fat: "high", sugars: "high", salt: "low", "saturated-fat": "high" }

  // --- Diet / ingredient analysis ---
  isVegan                 Boolean?
  isVegetarian            Boolean?
  isPalmOilFree           Boolean?
  ingredientsAnalysisTags String[] // raw tags e.g. ["en:palm-oil","en:non-vegan","en:vegetarian"]

  // --- Packaging ---
  packagingTags      String[] // e.g. ["en:plastic","fr:pot-en-verre"]
  packagingMaterials String[] // e.g. ["en:clear-glass","en:pp-5-polypropylene"]
  packagingRecycling String[] // e.g. ["en:recycle-in-glass-bin"]
  packagingText      String?

  // --- Data quality ---
  completeness Float? // 0.0 - 1.0

  // --- Relations ---
  shoppingListItems ShoppingListItem[]
  pantryItems       PantryItem[]
  mealItems         MealItem[]
  recipeIngredients RecipeIngredient[]

  @@index([name])
  @@index([createdAt])
  @@index([nutriscoreGrade])
  @@index([novaGroup])
  @@map("foods")
}

model FoodCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- NEVO metadata ---
  nevoVersion      String // e.g. "NEVO-Online 2025 9.0"
  foodGroup        String // e.g. "Potatoes and tubers"
  nevoCode         Int     @unique // NEVO food identifier
  foodName         String // English food name
  synonym          String? // Synonym if available
  quantity         String? // e.g. "per 100g"
  containsTracesOf String? // Traces of allergens
  isFortifiedWith  String? // Fortification info

  // --- Energy ---
  energyKj   Float? // Energy (kJ)
  energyKcal Float? // Energy (kcal)

  // --- Macronutrients ---
  water          Float? // Water (g)
  proteins       Float? // Protein total (g)
  proteinsPlant  Float? // Protein plant (g)
  proteinsAnimal Float? // Protein animal (g)
  nitrogenTotal  Float? // Nitrogen total (g)
  tryptophan     Float? // Tryptophan (mg)
  fat            Float? // Fat total (g)
  carbohydrates  Float? // Carbohydrates total (g)
  sugars         Float? // Sugars (g)
  addedSugars    Float? // Non-milk extrinsic sugars / added + free sugars (g)
  starch         Float? // Starch (g)
  polyols        Float? // Polyols (g)
  fiber          Float? // Dietary fibre total (g)
  alcohol        Float? // Alcohol (g)
  organicAcids   Float? // Organic acids (g)
  ash            Float? // Ash (g)

  // --- Fatty acids summary ---
  fattyAcidsTotal    Float? // Fatty acids total (g)
  saturatedFat       Float? // Saturated fatty acids (g)
  monoUnsaturatedFat Float? // Mono-unsaturated fatty acids cis (g)
  polyUnsaturatedFat Float? // Poly-unsaturated fatty acids (g)
  omega3Fat          Float? // Poly-unsaturated fatty acids n-3 (g)
  omega6Fat          Float? // Poly-unsaturated fatty acids n-6 (g)
  transFat           Float? // Trans fatty acids (g)

  // --- Minerals ---
  chloride    Float? // Chloride (mg)
  sodium      Float? // Sodium (mg)
  salt        Float? // Salt (g) — for recipe aggregation consistency with Food
  potassium   Float? // Potassium (mg)
  calcium     Float? // Calcium (mg)
  phosphorus  Float? // Phosphorus (mg)
  magnesium   Float? // Magnesium (mg)
  iron        Float? // Iron (mg)
  ironHaem    Float? // Haem iron (mg)
  ironNonHaem Float? // Non-haem iron (mg)
  copper      Float? // Copper (mg)
  selenium    Float? // Selenium (µg)
  zinc        Float? // Zinc (mg)
  iodine      Float? // Iodine (µg)

  // --- Vitamins ---
  vitaminA               Float? // Vitamin A (µg) — for recipe aggregation; backfill from vitaminARae
  vitaminARae            Float? // Vitamin A - retinol activity equivalents (µg)
  vitaminARe             Float? // Vitamin A - retinol equivalents (µg)
  retinol                Float? // Retinol (µg)
  betaCarotene           Float? // Beta-carotene total (µg)
  alphaCarotene          Float? // Alpha-carotene (µg)
  lutein                 Float? // Lutein (µg)
  zeaxanthin             Float? // Zeaxanthin (µg)
  betaCryptoxanthin      Float? // Beta-cryptoxanthin (µg)
  lycopene               Float? // Lycopene (µg)
  vitaminD               Float? // Vitamin D (µg)
  hydroxyCholecalciferol Float? // 25-hydroxycholecalciferol (µg)
  cholecalciferol        Float? // Cholecalciferol / D3 (µg)
  ergocalciferol         Float? // Ergocalciferol / D2 (µg)
  vitaminE               Float? // Vitamin E (mg)
  alphaTocopherol        Float? // Alpha-tocopherol (mg)
  betaTocopherol         Float? // Beta-tocopherol (mg)
  deltaTocopherol        Float? // Delta-tocopherol (mg)
  gammaTocopherol        Float? // Gamma-tocopherol (mg)
  vitaminK               Float? // Vitamin K (µg)
  vitaminK1              Float? // Vitamin K1 (µg)
  vitaminK2              Float? // Vitamin K2 (µg)
  thiamin                Float? // Thiamin / B1 (mg)
  riboflavin             Float? // Riboflavin / B2 (mg)
  vitaminB6              Float? // Vitamin B6 (mg)
  vitaminB12             Float? // Vitamin B12 (µg)
  niacinEquivalents      Float? // Niacin equivalents (mg)
  niacin                 Float? // Niacin (mg)
  folateTotal            Float? // Folate total (µg)
  folateFood             Float? // Folate food (µg)
  folicAcid              Float? // Folic acid (µg)
  vitaminC               Float? // Vitamin C (mg)

  // --- Individual saturated fatty acids (g) ---
  fa4_0                 Float?
  fa6_0                 Float?
  fa8_0                 Float?
  fa10_0                Float?
  fa11_0                Float?
  fa12_0                Float?
  fa13_0                Float?
  fa14_0                Float?
  fa15_0                Float?
  fa16_0                Float?
  fa17_0                Float?
  fa18_0                Float?
  fa19_0                Float?
  fa20_0                Float?
  fa21_0                Float?
  fa22_0                Float?
  fa23_0                Float?
  fa24_0                Float?
  fa25_0                Float?
  fa26_0                Float?
  saturatedFatRemainder Float? // Saturated fatty acids unknown/remainder (g)

  // --- Individual cis-monounsaturated fatty acids (g) ---
  fa10_1cis                   Float?
  fa12_1cis                   Float?
  fa14_1cis                   Float?
  fa16_1cis                   Float?
  fa18_1cis                   Float?
  fa20_1cis                   Float?
  fa22_1cis                   Float?
  fa24_1cis                   Float?
  monoUnsaturatedFatRemainder Float? // Cis-monounsaturated fatty acids unknown/remainder (g)

  // --- Individual polyunsaturated fatty acids (g) ---
  fa18_2cn6                   Float?
  fa18_2cn9                   Float?
  fa18_2ct                    Float?
  fa18_2tc                    Float?
  fa18_2r                     Float?
  fa18_3cn3                   Float?
  fa18_3cn6                   Float?
  fa18_4cn3                   Float?
  fa20_2cn6                   Float?
  fa20_3cn9                   Float?
  fa20_3cn6                   Float?
  fa20_3cn3                   Float?
  fa20_4cn6                   Float?
  fa20_4cn3                   Float?
  fa20_5cn3                   Float?
  fa21_5cn3                   Float?
  fa22_2cn6                   Float?
  fa22_2cn3                   Float?
  fa22_3cn3                   Float?
  fa22_4cn6                   Float?
  fa22_5cn6                   Float?
  fa22_5cn3                   Float?
  fa22_6cn3                   Float?
  fa24_2cn6                   Float?
  polyUnsaturatedFatRemainder Float? // Polyunsaturated fatty acids unknown/remainder (g)

  // --- Individual trans fatty acids (g) ---
  fa10_1trans       Float?
  fa12_1trans       Float?
  fa14_1trans       Float?
  fa16_1trans       Float?
  fa18_1trans       Float?
  fa18_2ttN6        Float?
  fa18_3tttN3       Float?
  fa20_1trans       Float?
  fa20_2tt          Float?
  fa22_1trans       Float?
  fa24_1trans       Float?
  transFatRemainder Float? // Trans fatty acids unknown/remainder (g)

  // --- Other ---
  fattyAcidsUnidentified Float? // Unknown/unidentified fatty acids (g)

  // --- Relations ---
  shoppingListItems ShoppingListItem[]
  pantryItems       PantryItem[]
  mealItems         MealItem[]
  recipeIngredients RecipeIngredient[]

  @@index([foodGroup])
  @@index([foodName])
  @@index([nevoCode])
  @@map("food_categories")
}

model FoodShelfLife {
  id                           String   @id @default(uuid())
  foodKeeperProductId          Int      @unique
  name                         String
  keywords                     String[]
  categoryName                 String?
  defaultStorageType           String? // "pantry" | "refrigerator" | "freezer"
  pantryMinDays                Int?
  pantryMaxDays                Int?
  pantryAfterOpeningDays       Int?
  refrigeratorMinDays          Int?
  refrigeratorMaxDays          Int?
  refrigeratorAfterOpeningDays Int?
  freezerMinDays               Int?
  freezerMaxDays               Int?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([name])
  @@index([categoryName])
  @@map("food_shelf_life")
}

model User {
  id                          String             @id @default(uuid())
  keycloakId                  String             @unique
  email                       String             @unique
  firstName                   String?
  lastName                    String?
  username                    String?            @unique
  yearOfBirth                 Int?
  country                     String?
  region                      String?
  zip                         String?
  language                    String?
  preferences                 Json               @default("{}") // Flexible JSON for app-specific preferences
  settings                    Json               @default("{}") // Flexible JSON for app-specific settings
  gender                      Gender?
  annualIncome                AnnualIncomeLevel?
  educationLevel              EducationLevel?
  weightKg                    Float?
  heightCm                    Float?
  activityLevel               ActivityLevel?
  healthGoals                 Json?              @default("{}")
  nutritionTargets            Json?              @default("{}")
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  autoAddCheckedItemsToPantry Boolean            @default(true)

  // Relations
  shoppingList      ShoppingList[]
  pantry            Pantry?
  recipes           Recipe[]
  meals             Meal[]
  mealLogs          MealLog[]
  knowledge         Knowledge[]
  knowledgeProgress UserKnowledgeProgress[]
  challengeProgress ChallengeProgress[]
  missionProgress   MissionProgress[]
  groupMemberships  GroupMembership[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model ShoppingList {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingListItem[]

  @@unique([userId, title])
  @@index([userId])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String   @id @default(uuid())
  quantity       Int      @default(1)
  unit           Unit     @default(PIECES)
  notes          String?
  checked        Boolean  @default(false)
  shoppingListId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Polymorphic reference
  itemType       String  @default("food") // "food" | "food_category"
  foodId         String?
  foodCategoryId String?

  // Relations
  shoppingList ShoppingList  @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  food         Food?         @relation(fields: [foodId], references: [id], onDelete: SetNull)
  foodCategory FoodCategory? @relation(fields: [foodCategoryId], references: [id], onDelete: SetNull)

  @@unique([shoppingListId, foodId])
  @@unique([shoppingListId, foodCategoryId])
  @@index([shoppingListId])
  @@index([foodId])
  @@index([foodCategoryId])
  @@map("shopping_list_items")
}

model Pantry {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PantryItem[]

  @@index([userId])
  @@map("pantries")
}

model PantryItem {
  id               String    @id @default(uuid())
  quantity         Int       @default(1)
  unit             Unit      @default(PIECES)
  notes            String?
  location         String?
  expiryDate       DateTime?
  expiryDateSource String? // "manual" | "auto_foodkeeper"
  pantryId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Polymorphic reference
  itemType       String  @default("food") // "food" | "food_category"
  foodId         String?
  foodCategoryId String?

  // Relations
  pantry       Pantry        @relation(fields: [pantryId], references: [id], onDelete: Cascade)
  food         Food?         @relation(fields: [foodId], references: [id], onDelete: SetNull)
  foodCategory FoodCategory? @relation(fields: [foodCategoryId], references: [id], onDelete: SetNull)

  @@unique([pantryId, foodId])
  @@unique([pantryId, foodCategoryId])
  @@index([pantryId])
  @@index([foodId])
  @@index([foodCategoryId])
  @@index([expiryDate])
  @@map("pantry_items")
}

model Meal {
  id                  String         @id @default(uuid())
  name                String
  calories            Int?
  proteins            Int?
  nutritionalInfo     Json?
  sustainabilityScore Float?
  price               Float?
  barcode             String?        @unique
  userId              String
  recipeId            String? // Optional link to a recipe this meal is based on
  mealCategories      MealCategory[] @default([])
  mealCourse          MealCourse?
  dietaryLabels       DietaryLabel[] @default([])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe   Recipe?    @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  items    MealItem[]
  mealLogs MealLog[]

  @@index([userId])
  @@index([recipeId])
  @@map("meals")
}

model MealItem {
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  unit      Unit     @default(PIECES)
  notes     String?
  mealId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Polymorphic reference
  itemType       String  @default("food") // "food" | "food_category"
  foodId         String?
  foodCategoryId String?

  // Relations
  meal         Meal          @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food         Food?         @relation(fields: [foodId], references: [id], onDelete: SetNull)
  foodCategory FoodCategory? @relation(fields: [foodCategoryId], references: [id], onDelete: SetNull)

  @@unique([mealId, foodId])
  @@unique([mealId, foodCategoryId])
  @@index([mealId])
  @@index([foodId])
  @@index([foodCategoryId])
  @@map("meal_items")
}

model Recipe {
  id                  String      @id @default(uuid())
  userId              String? // Nullable for system recipes (TheMealDB, etc.)
  title               String
  description         String?
  instructions        String?
  prepTime            Int?
  cookTime            Int?
  servings            Int?
  difficulty          String?
  tags                String[]
  nutritionalInfo     Json?
  sustainabilityScore Float?
  price               Float?
  allergens           Allergens[]
  rating              Float       @default(0)
  ratingCount         Int         @default(0)
  externalId          String?     @unique // TheMealDB idMeal
  imageUrl            String?
  videoUrl            String?
  cuisineType         String? // Japanese, Italian, Mexican, etc.
  category            String? // Chicken, Seafood, Dessert, etc.
  isPublic            Boolean     @default(false)
  dietaryLabels       String[] // ["vegan", "vegetarian", "gluten-free"]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  meals       Meal[]
  ingredients RecipeIngredient[]

  @@index([userId])
  @@index([isPublic])
  @@index([category])
  @@index([cuisineType])
  @@index([isPublic, category])
  @@map("recipes")
}

model RecipeIngredient {
  id        String   @id @default(uuid())
  recipeId  String
  name      String // Original ingredient name from recipe
  measure   String? // Amount/measurement string
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Polymorphic reference
  itemType       String  @default("food_category") // "food" | "food_category"
  foodId         String?
  foodCategoryId String?

  // Relations
  recipe       Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  food         Food?         @relation(fields: [foodId], references: [id], onDelete: SetNull)
  foodCategory FoodCategory? @relation(fields: [foodCategoryId], references: [id], onDelete: SetNull)

  @@index([recipeId])
  @@index([foodId])
  @@index([foodCategoryId])
  @@map("recipe_ingredients")
}

model MealLog {
  id             String     @id @default(uuid())
  userId         String
  mealId         String
  typeOfMeal     TypeOfMeal
  timestamp      DateTime   @default(now())
  mealFromPantry Boolean    @default(false)
  eatenOut       Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([typeOfMeal])
  @@index([userId, typeOfMeal])
  @@map("meal_logs")
}

model Mission {
  id          String   @id @default(uuid())
  title       String
  description String
  available   Boolean  @default(false)
  startDate   DateTime
  endDate     DateTime
  content     Json     @default("{}") // Flexible JSON for mission-specific content

  // Relations
  missionProgresses MissionProgress[]

  @@map("missions")
}

model MissionProgress {
  userId    String
  missionId String
  completed Boolean @default(false)
  progress  Float

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@id([userId, missionId])
  @@map("mission_progress")
}

model Challenge {
  id          String   @id @default(uuid())
  title       String
  description String
  available   Boolean  @default(false)
  startDate   DateTime
  endDate     DateTime
  content     Json     @default("{}") // Flexible JSON for challenge-specific content

  // Relations
  challengeProgresses ChallengeProgress[]

  @@map("challenges")
}

model ChallengeProgress {
  userId      String
  challengeId String
  completed   Boolean @default(false)
  progress    Float

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId])
  @@map("challenge_progress")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
  PREFER_NOT_TO_SAY
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum AnnualIncomeLevel {
  BELOW_10000
  FROM_10000_TO_19999
  FROM_20000_TO_34999
  FROM_35000_TO_49999
  FROM_50000_TO_74999
  FROM_75000_TO_99999
  ABOVE_100000
}

enum EducationLevel {
  NO_FORMAL_EDUCATION
  PRIMARY
  SECONDARY
  VOCATIONAL
  BACHELORS
  MASTERS
  DOCTORATE
}

enum Unit {
  PIECES
  G
  KG
  ML
  L
  CUPS
}

enum TypeOfMeal {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  DRINKS
  OTHER
}

enum MealCategory {
  ANIMAL_PROTEIN // Meat, Poultry, Eggs
  SEAFOOD
  PLANT_PROTEIN // Beans, Legumes, Plant-based meats
  STARCH_GRAIN // Pasta, Rice, Potatoes
  VEGGIES_FRUIT // Fruits & Veggies
  DAIRY
  MIXED_OTHER
}

enum MealCourse {
  MAIN_DISH // The anchor of the meal
  SIDE_SNACK // Anything eaten with a main or between meals
  DESSERT // Sweets and treats
  BEVERAGE // All liquids
  SAUCE_OTHER // Sauces, dressings, or "Other"
}

enum Allergens {
  GLUTEN // Wheat, barley, rye
  DAIRY // Milk, cheese, butter, lactose
  PEANUTS // Specifically groundnuts
  TREE_NUTS // Almonds, walnuts, cashews, etc.
  SHELLFISH // Shrimp, crab, lobster
  FISH // Finfish (some are allergic to fish but not shellfish)
  EGGS // Very common in baking/sauces
  SOY // Found in many processed foods and plant proteins
  SESAME // Increasingly recognized as a major allergen
  SULFITES // Common in wine and dried fruits
  MUSTARD // Common in European labeling requirements
  NIGHTSHADES // (Optional) Peppers, potatoes, tomatoes (common sensitivity)
  OTHER
}

enum DietaryLabel {
  VEGAN
  VEGETARIAN
  PESCATARIAN
  GLUTEN_FREE
  DAIRY_FREE
  NUT_FREE
  HALAL
  KOSHER
}

enum GroupRole {
  ADMIN
  MEMBER
}

model UserGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  inviteCode  String   @unique
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  memberships GroupMembership[]

  @@index([inviteCode])
  @@index([createdBy])
  @@map("user_groups")
}

model GroupMembership {
  id            String             @id @default(uuid())
  groupId       String
  userId        String?
  role          GroupRole          @default(MEMBER)
  nickname      String?
  age           Int?
  gender        Gender?
  preferences   Json               @default("{}")
  activityLevel ActivityLevel?
  annualIncome  AnnualIncomeLevel?
  createdBy     String?
  joinedAt      DateTime           @default(now())
  updatedAt     DateTime?          @updatedAt

  // Relations
  user  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([createdBy])
  @@map("group_memberships")
}

model Knowledge {
  id          String   @id @default(uuid())
  userId      String // Creator/owner of the knowledge item
  title       String
  description String?
  available   Boolean  @default(true)
  content     Json // Stores quiz data: { questions: [{ question, options, correctAnswer }] }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userProgress UserKnowledgeProgress[]

  @@index([userId])
  @@index([available])
  @@map("knowledge")
}

model UserKnowledgeProgress {
  id             String   @id @default(uuid())
  userId         String
  knowledgeId    String
  completed      Boolean  @default(false)
  progress       Json     @default("{}") // Stores: { currentQuestionIndex, answers, score }
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgeId])
  @@index([userId])
  @@index([knowledgeId])
  @@map("user_knowledge_progress")
}
