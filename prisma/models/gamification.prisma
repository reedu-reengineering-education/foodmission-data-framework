// ============================================================
// Gamification - Missions, quests, challenges, and knowledge
// ============================================================

enum ProgressTrackingType {
  SOFT
  PRECISION
  ACHIEVEMENT
}

enum ChallengeScope {
  DAILY_STANDALONE
  QUEST_ONE_TIME
}

enum ProgressStatus {
  ACTIVE
  ACHIEVED
  NOT_ACHIEVED
}

model Mission {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  available   Boolean  @default(false)
  startDate   DateTime
  endDate     DateTime
  content     Json     @default("{}") // Flexible JSON for mission-specific content

  // Relations
  missionProgresses MissionProgress[]
  quests            Quest[]

  @@map("missions")
}

model MissionProgress {
  userId    String
  missionId String
  completed Boolean @default(false)
  progress  Float

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@id([userId, missionId])
  @@map("mission_progress")
}

model Quest {
  id                   String               @id @default(uuid())
  slug                 String               @unique
  missionId            String
  title                String
  description          String
  topicSlug            String?
  sortOrder            Int                  @default(0)
  available            Boolean              @default(true)
  isPetQuest           Boolean              @default(false)
  streakEnabled        Boolean              @default(false)
  progressTrackingType ProgressTrackingType @default(SOFT)
  content              Json                 @default("{}")

  // Relations
  mission         Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)
  questProgresses QuestProgress[]
  challenges      Challenge[]

  @@index([missionId])
  @@map("quests")
}

model QuestProgress {
  userId         String
  questId        String
  completed      Boolean   @default(false)
  progress       Float     @default(0)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActionAt   DateTime?

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@id([userId, questId])
  @@map("quest_progress")
}

model Challenge {
  id             String         @id @default(uuid())
  slug           String         @unique
  title          String
  description    String
  available      Boolean        @default(false)
  startDate      DateTime
  endDate        DateTime
  questId        String?
  challengeScope ChallengeScope @default(DAILY_STANDALONE)
  content        Json           @default("{}")

  // Relations
  quest               Quest?              @relation(fields: [questId], references: [id], onDelete: SetNull)
  challengeProgresses ChallengeProgress[]

  @@index([questId])
  @@index([challengeScope])
  @@map("challenges")
}

model ChallengeProgress {
  userId      String
  challengeId String
  completed   Boolean        @default(false)
  progress    Float
  status      ProgressStatus @default(ACTIVE)

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId])
  @@map("challenge_progress")
}

model Knowledge {
  id          String   @id @default(uuid())
  slug        String   @unique
  userId      String // Creator/owner of the knowledge item
  title       String
  description String?
  available   Boolean  @default(true)
  content     Json // Stores quiz data: { questions: [{ question, options, correctAnswer }] }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userProgress UserKnowledgeProgress[]

  @@index([userId])
  @@index([available])
  @@map("knowledge")
}

model UserKnowledgeProgress {
  id             String   @id @default(uuid())
  userId         String
  knowledgeId    String
  completed      Boolean  @default(false)
  progress       Json     @default("{}") // Stores: { currentQuestionIndex, answers, score }
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgeId])
  @@index([userId])
  @@index([knowledgeId])
  @@map("user_knowledge_progress")
}
