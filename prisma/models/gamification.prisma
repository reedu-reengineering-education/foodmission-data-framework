// ============================================================
// Gamification - Missions, challenges, knowledge, wallet, indicators
// ============================================================

enum ProgressIndicatorKind {
  // SOFT bars
  FOOD_CHOICES
  FOOD_AND_WASTE
  HEALTH
  // SOFT wheels
  CO2_REDUCTION
  ENERGY_REDUCTION
  WATER_SAVINGS
  LAND_USE_REDUCTION
  // PRECISE nutrition
  PROTEIN
  FAT
  SUGAR
  SALT
  FIBER
  VITAMINS
  CALORIES
}

enum ProgressPrecision {
  SOFT
  PRECISE
}

enum WalletCurrency {
  XP
  POINTS
}

model Mission {
  id          String   @id @default(uuid())
  title       String
  description String
  available   Boolean  @default(false)
  startDate   DateTime
  endDate     DateTime
  content     Json     @default("{}") // Flexible JSON for mission-specific content

  // Relations
  missionProgresses MissionProgress[]

  @@map("missions")
}

model MissionProgress {
  userId    String
  missionId String
  completed Boolean @default(false)
  progress  Float

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@id([userId, missionId])
  @@map("mission_progress")
}

model Challenge {
  id          String   @id @default(uuid())
  title       String
  description String
  available   Boolean  @default(false)
  startDate   DateTime
  endDate     DateTime
  content     Json     @default("{}") // Flexible JSON for challenge-specific content

  // Relations
  challengeProgresses ChallengeProgress[]

  @@map("challenges")
}

model ChallengeProgress {
  userId      String
  challengeId String
  completed   Boolean @default(false)
  progress    Float

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId])
  @@map("challenge_progress")
}

model Knowledge {
  id          String   @id @default(uuid())
  userId      String // Creator/owner of the knowledge item
  title       String
  description String?
  available   Boolean  @default(true)
  content     Json // Stores quiz data: { questions: [{ question, options, correctAnswer }] }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userProgress UserKnowledgeProgress[]

  @@index([userId])
  @@index([available])
  @@map("knowledge")
}

model UserKnowledgeProgress {
  id             String   @id @default(uuid())
  userId         String
  knowledgeId    String
  completed      Boolean  @default(false)
  progress       Json     @default("{}") // Stores: { currentQuestionIndex, answers, score }
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgeId])
  @@index([userId])
  @@index([knowledgeId])
  @@map("user_knowledge_progress")
}

model UserGamificationWallet {
  userId    String   @id
  level     Int      @default(1)
  xp        Int      @default(0)
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_gamification_wallets")
}

/// Append-only history of wallet balance changes (XP / points).
model WalletEntry {
  id           String        @id @default(uuid())
  userId       String
  currency     WalletCurrency
  amount       Int // signed: credit > 0, debit < 0
  balanceAfter Int
  reason       String
  eventId      String?
  createdAt    DateTime      @default(now())

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  event UserEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventId])
  @@map("wallet_entries")
}

/// Same shape for personal and group progress indicators.
/// Exactly one of userId / groupId must be set
/// (DB CHECK `progress_indicators_owner_xor` in manual migration).
model ProgressIndicator {
  id               String                 @id @default(uuid())
  userId           String?
  groupId          String?
  kind             ProgressIndicatorKind
  precision        ProgressPrecision
  level            Int                    @default(1) // 1–5
  accumulatedValue Float                  @default(0) // current cycle
  targetValue      Float
  allTimeTotal     Float                  @default(0)
  cycleStartedAt   DateTime               @default(now())
  lastUpdatedAt    DateTime               @updatedAt

  user  User?      @relation("UserProgressIndicators", fields: [userId], references: [id], onDelete: Cascade)
  group UserGroup? @relation("GroupProgressIndicators", fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@unique([groupId, kind])
  @@index([userId])
  @@index([groupId])
  @@map("progress_indicators")
}
