  batch            MealLogAnalyticsBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  date             DateTime       @db.Date
  foodName         String
  foodGroup        String?
  itemType         String
  frequency        Int
  uniqueUsers      Int
  avgQuantity      Float
  predominantUnit  String

  createdAt DateTime @default(now())

  @@unique([batchId, date, foodName, itemType])
  @@index([date])
  @@index([frequency])
  @@map("meal_log_analytics_food_popularity")
}

