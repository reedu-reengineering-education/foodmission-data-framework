// ============================================================
// Analytics — Cross-Dimensional Breakdown Tables
//
// Each row represents one (date, typeOfMeal, dim1Name, dim1Value, dim2Name, dim2Value)
// combination where EXACTLY TWO demographic dimensions are active simultaneously.
// This enables queries like "ageGroup=65_plus AND gender=MALE".
//
// Storage design:
//   - dim1Name / dim2Name  hold the dimension name (e.g. "ageGroup", "gender")
//   - dim1Value / dim2Value hold the value      (e.g. "65_plus", "MALE")
//   - dim1Name < dim2Name  alphabetically (enforced in aggregator) to prevent
//     duplicate pairs (ageGroup+gender == gender+ageGroup).
//
// k-anonymity: K=20 enforced (stricter than single-dim K=5) because combining
// two dimensions increases re-identification risk.
//
// 10 possible pairs from 5 dimensions:
//   ageGroup+country, ageGroup+educationLevel, ageGroup+gender,
//   ageGroup+region, country+educationLevel, country+gender,
//   country+region, educationLevel+gender, educationLevel+region, gender+region
// ============================================================

model MealLogAnalyticsCrossDimNutrition {
  id         String         @id @default(uuid())
  batchId    String
  batch      MealLogAnalyticsBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  date       DateTime       @db.Date
  typeOfMeal TypeOfMeal

  // Two active dimensions; dim1Name < dim2Name alphabetically
  dim1Name  String
  dim1Value String
  dim2Name  String
  dim2Value String

  userCount       Int
  mealCount       Int
  avgCalories     Float?
  avgProteins     Float?
  avgFat          Float?
  avgCarbs        Float?
  avgFiber        Float?
  avgSodium       Float?
  avgSugar        Float?
  avgSaturatedFat Float?
  p25Calories     Float?
  p50Calories     Float?
  p75Calories     Float?

  createdAt DateTime @default(now())

  @@unique([batchId, date, typeOfMeal, dim1Name, dim1Value, dim2Name, dim2Value])
  @@index([dim1Name, dim2Name])
  @@index([date])
  @@map("meal_log_analytics_cross_dim_nutrition")
}

