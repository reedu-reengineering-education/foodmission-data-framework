// ============================================================
// Analytics - Meal Logs
// ============================================================

enum AnalyticsBatchStatus {
  STAGING
  APPROVED
  PUBLISHED
  REJECTED
  SUPERSEDED
}

model MealLogAnalyticsBatch {
  id              String               @id @default(uuid())
  periodStart     DateTime
  periodEnd       DateTime
  status          AnalyticsBatchStatus         @default(STAGING)
  generatedAt     DateTime             @default(now())
  publishedAt     DateTime?
  publishedBy     String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  recordCount     Int                  @default(0)
  metadata        Json?

  dailyNutrition           MealLogAnalyticsDailyNutrition[]
  foodPopularity           MealLogAnalyticsFoodPopularity[]
  mealPatterns             MealLogAnalyticsMealPatterns[]
  sustainability           MealLogAnalyticsSustainability[]
  mealClassification       MealLogAnalyticsMealClassification[]
  mealRecords              MealLogAnalyticsMealRecord[]
  demographicNutrition      MealLogAnalyticsDemographicNutrition[]
  demographicClassification MealLogAnalyticsDemographicClassification[]
  demographicPatterns       MealLogAnalyticsDemographicPatterns[]
  crossDimNutrition         MealLogAnalyticsCrossDimNutrition[]
  crossDimClassification    MealLogAnalyticsCrossDimClassification[]
  crossDimPatterns          MealLogAnalyticsCrossDimPatterns[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("meal_log_analytics_batches")
}

model MealLogAnalyticsDailyNutrition {
  id              String         @id @default(uuid())
  batchId         String
  batch           MealLogAnalyticsBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  date            DateTime       @db.Date
  typeOfMeal      TypeOfMeal
  userCount       Int
  mealCount       Int
  avgCalories     Float?
  avgProteins     Float?
  avgFat          Float?
  avgCarbs        Float?
  avgFiber        Float?
  avgSodium       Float?
  avgSugar        Float?
  avgSaturatedFat Float?
  p25Calories     Float?
  p50Calories     Float?
  p75Calories     Float?

  createdAt DateTime @default(now())

  @@unique([batchId, date, typeOfMeal])
  @@index([date])
  @@map("meal_log_analytics_daily_nutrition")
}

model MealLogAnalyticsFoodPopularity {
  id               String         @id @default(uuid())
