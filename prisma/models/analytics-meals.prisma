// One row per individual meal log — no userId, no mealId, date-only timestamp.
// Enables microdata analysis while preserving anonymity (k-anonymity enforced at batch level).
model MealLogAnalyticsMealRecord {
  id         String         @id @default(uuid())
  batchId    String
  batch      MealLogAnalyticsBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  // Temporal — weeks elapsed since the user registered when this meal was logged.
  // Never stores absolute dates, preserving anonymity.
  weeksSinceRegistration Int
  typeOfMeal TypeOfMeal

  // Aggregated nutrition (sum of all items in the meal, scaled to actual quantity)
  totalCalories    Float?
  totalProteins    Float?
  totalFat         Float?
  totalCarbs       Float?
  totalFiber       Float?
  totalSodium      Float?
  totalSugar       Float?
  totalSaturatedFat Float?

  // Scores — mode of items in the meal (only from OpenFoodFacts items)
  nutriScoreGrade  String? // A–E, dominant grade across items
  ecoScoreGrade    String? // a–e, dominant grade across items

  // Processing — item-count based
  novaGroupMode    Int?    // Most common NOVA group among items (1–4)
  ultraProcessedPct Float? // % of items that are NOVA group 4

  // Sustainability
  sustainabilityScore Float? // From Meal.sustainabilityScore
  totalCarbonFootprint Float? // Sum of item carbon footprints

  // Classification flags
  isVegetarian Boolean
  isVegan      Boolean

  // Meal composition
  itemCount    Int

  createdAt DateTime @default(now())

  @@index([batchId, weeksSinceRegistration])
  @@index([weeksSinceRegistration, typeOfMeal])
  @@map("meal_log_analytics_meal_records")
}

// ============================================================
// Analytics - Demographic Breakdown Tables
//
// Each row represents one (date, typeOfMeal, demographicValue) combination
// for EXACTLY ONE demographic dimension (ageGroup | gender | educationLevel | region | country).
// The other three dimension columns are NULL in that row. This prevents
// cross-dimensional re-identification.
//
// Users who have not set a demographic field appear under the '__null__'
// sentinel value for that dimension.
//
// k-anonymity (K=5) is enforced before insertion: rows with userCount < 5
// are suppressed.
// ============================================================

// Demographic breakdown of daily nutrition averages
model MealLogAnalyticsDemographicNutrition {
  id         String         @id @default(uuid())
  batchId    String
  batch      MealLogAnalyticsBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  date       DateTime       @db.Date
  typeOfMeal TypeOfMeal

  dimensionName  String
  dimensionValue String

  userCount       Int
  mealCount       Int
  avgCalories     Float?
  avgProteins     Float?
  avgFat          Float?
  avgCarbs        Float?
  avgFiber        Float?
  avgSodium       Float?
  avgSugar        Float?
  avgSaturatedFat Float?
  p25Calories     Float?
  p50Calories     Float?
  p75Calories     Float?

  createdAt DateTime @default(now())

  @@unique([batchId, date, typeOfMeal, dimensionName, dimensionValue])
  @@index([date])
  @@index([dimensionName])
  @@map("meal_log_analytics_demographic_nutrition")
}

// Demographic breakdown of meal classification (vegetarian/vegan/NOVA/ultra-processed)
model MealLogAnalyticsDemographicClassification {
  id         String         @id @default(uuid())
