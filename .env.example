# Environment variables template
# Copy this file to .env and update the values for your environment

# Application Configuration
NODE_ENV="development"
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/foodmission_db?schema=public"
DATABASE_URL_TEST="postgresql://postgres:password@localhost:5432/foodmission_test_db?schema=public"

# Keycloak Configuration
KEYCLOAK_BASE_URL="http://localhost:8080"
KEYCLOAK_REALM="foodmission"
KEYCLOAK_CLIENT_ID="foodmission-api"
KEYCLOAK_CLIENT_SECRET="your-keycloak-client-secret"
KEYCLOAK_REDIRECT_URI="http://localhost:3000/auth/callback"
KEYCLOAK_SERVICE_CLIENT_ID="foodmission-service"
KEYCLOAK_SERVICE_CLIENT_SECRET="test-secret-service"

# Logging Configuration
LOG_LEVEL="info"

# OpenTelemetry Configuration
# Enable OpenTelemetry logging and tracing (set to "true" to enable)
OTEL_LOGS_ENABLED="true"
# OTEL Collector endpoint (collector routes logs and traces to backends)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# Optional: OTLP headers for authentication (JSON format)
# OTEL_EXPORTER_OTLP_HEADERS='{"Authorization":"Bearer your-token-here"}'
# Service name for OpenTelemetry (default: foodmission-api)
OTEL_SERVICE_NAME="foodmission-api"
# Service namespace for OpenTelemetry - used in Loki job label as {namespace}/{service-name}
OTEL_SERVICE_NAMESPACE="foodmission"
# Service version for OpenTelemetry (default: uses npm_package_version)
# OTEL_SERVICE_VERSION="1.0.0"

# Redis Configuration (if using external Redis)
# REDIS_URL="redis://localhost:6379"

# OpenFoodFacts Configuration (optional)
# OPENFOODFACTS_API_URL="https://world.openfoodfacts.org"
# OPENFOODFACTS_RATE_LIMIT=100

# CORS Configuration (optional)
# CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Monitoring Configuration (optional)
# ENABLE_METRICS="true"
# METRICS_PORT=9090
# SENTRY_DSN="your-sentry-dsn"