{
  "name": "foodmission-data-framework",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "form-data": "4.0.6"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathPatterns=\"src/.*\\.spec\\.ts$\"",
    "test:integration": "jest --testPathPatterns=\"test/.*\\.integration\\.spec\\.ts$\"",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:all": "jest --coverage --testPathPatterns=\"(src/.*\\.spec\\.ts$|test/.*\\.(integration|e2e)-spec\\.ts$)\"",
    "test:otel": "ts-node scripts/test-otel-setup.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed -- --environment development",
    "db:seed:prod": "prisma db seed -- --environment production",
    "db:seed:test": "ts-node scripts/dev/seed-test.ts",
    "db:seed:foods": "ts-node scripts/seeds/seed-food-products-only.ts",
    "db:seed:meal-logs": "ts-node scripts/seeds/dev/seed-meal-logs.ts",
    "db:seed:shopping-lists": "ts-node scripts/seeds/dev/seed-shopping-lists.ts",
    "db:clean:meal-logs": "ts-node scripts/dev/clean-meal-logs.ts",
    "db:clean:shopping-lists": "ts-node scripts/dev/clean-shopping-lists.ts",
    "db:clean:analytics": "ts-node scripts/dev/clean-analytics.ts",
    "db:backup": "./scripts/db-backup.sh",
    "db:backup:full": "./scripts/db-backup.sh full",
    "db:backup:data": "./scripts/db-backup.sh data",
    "db:backup:schema": "./scripts/db-backup.sh schema",
    "db:backup:all": "./scripts/db-backup.sh all",
    "db:restore": "./scripts/db-restore.sh",
    "db:restore:latest": "./scripts/db-restore.sh latest",
    "db:restore:interactive": "./scripts/db-restore.sh interactive",
    "migrate": "ts-node scripts/migration-utils.ts",
    "dev:setup": "./scripts/dev-setup.sh",
    "dev:reset": "./scripts/db-reset.sh",
    "ci:test": "./scripts/ci-local-test.sh",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:logs": "docker compose -f docker-compose.yml logs -f",
    "docs:generate": "ts-node scripts/generate-openapi-spec.ts"
  },
  "dependencies": {
    "@cacheable/memory": "^2.0.9",
    "@keyv/redis": "^5.1.6",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.19.3",
    "@prisma/instrumentation": "^6.16.2",
    "axios": "^1.17.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cls-hooked": "^4.2.2",
    "dotenv": "^17.4.1",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "iso-3166-2": "^1.0.0",
    "iso-639-1": "^3.1.5",
    "joi": "^18.2.1",
    "keycloak-connect": "^26.1.1",
    "keyv": "^5.5.1",
    "nest-keycloak-connect": "^2.0.0-alpha.3",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.27",
    "@types/cache-manager": "^5.0.0",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/iso-3166-2": "^1.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "js-yaml": "^4.2.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "volta": {
    "node": "24.0.0"
  }
}
